# Backend (FastAPI)
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=postgresql://capital_ops:capital_ops@localhost:5432/capital_ops

# Frontend (Next.js)
# Used by the frontend API client to call the backend in local dev.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# CORS
CORS_ORIGINS=http://localhost:3000

# Postgres (docker-compose)
POSTGRES_DB=capital_ops
POSTGRES_USER=capital_ops
POSTGRES_PASSWORD=capital_ops
